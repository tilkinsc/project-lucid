{
  "$schema": "http://json-schema.org/draft/2020-12/schema#",
  "title": "C3 Project Configuration",
  "description": "JSON Schema for C3 project.json files with per-target overrides",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "langrev": { "type": "string", "const": "1" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "dependency-search-paths": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "authors": { "type": "array", "items": { "type": "string" } },
    "version": { "type": "string" },
    "features": { "type": "array", "items": { "type": "string" } },
    "target": { "type": "string", "enum": [
      "android-aarch64",
      "elf-aarch64", "elf-riscv32", "elf-riscv64", "elf-x86", "elf-x64", "elf-xtensa",
      "mcu-x86", "mingw-x64", "netbsd-x86", "netbsd-x64", "openbsd-x86", "openbsd-x64",
      "freebsd-x86", "freebsd-x64", "ios-aarch64",
      "linux-aarch64", "linux-riscv32", "linux-riscv64", "linux-x86", "linux-x64",
      "macos-aarch64", "macos-x64",
      "wasm32", "wasm64",
      "windows-aarch64", "windows-x64"
    ] },
    "no-entry": { "type": "boolean" },
    "sources": { "type": "array", "items": { "type": "string" } },
    "test-sources": { "type": "array", "items": { "type": "string" } },
    "c-sources": { "type": "array", "items": { "type": "string" } },
    "c-include-dirs": { "type": "array", "items": { "type": "string" } },
    "output": { "type": "string" },
    "cc": { "type": "string" },
    "cpu": { "type": "string" },
    "debug-info": { "type": "string", "enum": ["none", "full", "line-tables"] },
    "fp-math": { "type": "string", "enum": ["strict", "relaxed", "fast"] },
    "link-libc": { "type": "boolean" },
    "memory-env": { "type": "string", "enum": ["normal", "small", "tiny", "none"] },
    "opt": { "type": "string", "enum": ["O0","O1","O2","O3","O4","O5","Os","Oz"] },
    "optlevel": { "type": "string", "enum": ["none","less","more","max"] },
    "optsize": { "type": "string", "enum": ["none","small","tiny"] },
    "reloc": { "type": "string", "enum": ["none","pic","PIC","pie","PIE"] },
    "trap-on-wrap": { "type": "boolean" },
    "safe": { "type": "boolean" },
    "single-module": { "type": "boolean" },
    "soft-float": { "type": "boolean" },
    "strip-unused": { "type": "boolean" },
    "symtab": { "type": "integer" },
    "linker": { "type": "string" },
    "use-stdlib": { "type": "boolean" },
    "panicfn": { "type": "string" },
    "x86cpu": { "type": "string", "enum": ["baseline","ssse3","sse4","avx1","avx2-v1","avx2-v2","avx512","native"] },
    "x86vec": { "type": "string", "enum": ["none","native","mmx","sse","avx","avx512"] },
    "targets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "type": { 
            "type": "string",
            "enum": ["executable","dynamic-lib","static-lib","benchmark","test","object-files","prepare"]
          },
          "target": { "type": "string", "enum": [
            "android-aarch64",
            "elf-aarch64", "elf-riscv32", "elf-riscv64", "elf-x86", "elf-x64", "elf-xtensa",
            "mcu-x86", "mingw-x64", "netbsd-x86", "netbsd-x64", "openbsd-x86", "openbsd-x64",
            "freebsd-x86", "freebsd-x64", "ios-aarch64",
            "linux-aarch64", "linux-riscv32", "linux-riscv64", "linux-x86", "linux-x64",
            "macos-aarch64", "macos-x64",
            "wasm32", "wasm64",
            "windows-aarch64", "windows-x64"
          ] },
          "no-entry": { "type": "boolean" },
          "sources": { "type": "array", "items": { "type": "string" } },
          "test-sources": { "type": "array", "items": { "type": "string" } },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "warnings": { "type": "array", "items": { "type": "string" } },
          "output": { "type": "string" },
          "cc": { "type": "string" },
          "c-sources": { "type": "array", "items": { "type": "string" } },
          "c-include-dirs": { "type": "array", "items": { "type": "string" } },
          "cpu": { "type": "string" },
          "debug-info": { "type": "string", "enum": ["none", "full", "line-tables"] },
          "fp-math": { "type": "string", "enum": ["strict", "relaxed", "fast"] },
          "link-libc": { "type": "boolean" },
          "memory-env": { "type": "string", "enum": ["normal", "small", "tiny", "none"] },
          "opt": { "type": "string", "enum": ["O0","O1","O2","O3","O4","O5","Os","Oz"] },
          "optlevel": { "type": "string", "enum": ["none","less","more","max"] },
          "optsize": { "type": "string", "enum": ["none","small","tiny"] },
          "reloc": { "type": "string", "enum": ["none","pic","PIC","pie","PIE"] },
          "trap-on-wrap": { "type": "boolean" },
          "safe": { "type": "boolean" },
          "single-module": { "type": "boolean" },
          "soft-float": { "type": "boolean" },
          "strip-unused": { "type": "boolean" },
          "symtab": { "type": "integer" },
          "linker": { "type": "string" },
          "use-stdlib": { "type": "boolean" },
          "panicfn": { "type": "string" },
          "x86cpu": { "type": "string", "enum": ["baseline","ssse3","sse4","avx1","avx2-v1","avx2-v2","avx512","native"] },
          "x86vec": { "type": "string", "enum": ["none","native","mmx","sse","avx","avx512"] }
        },
        "required": ["type"]
      }
    }
  },
  "required": ["sources"]
}
