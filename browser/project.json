{
    "$schema": "../schema.json",
    "version": "1.0.0",
    "authors": ["Cody Tilkins"],
    "langrev": "1",
    "warnings": ["all"],
    "sources": [ "**" ],
    "output": "build",
    "dependency-search-paths": [ "lib" ],
    "dependencies": [
        "raylib6"
    ],
    "target": "linux-x64",
    "safe": true,
    "targets": {
        "browser-release": {
            "type": "executable",
            "opt": "O2",
            "debug-info": "none"
        },
        "browser-debug": {
            "type": "executable",
            "opt": "O0",
            "debug-info": "full"
        }
    }
}
